{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "target": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["react", "react-native", "expo"]
  },
  "include": ["**/*.ts", "**/*.tsx", "index.js"],
  "exclude": ["supabase/functions/**"]
}
