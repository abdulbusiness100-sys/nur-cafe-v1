# -----------------------------
# Node template (base)
# -----------------------------
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage / build tools
lib-cov
coverage
*.lcov
.nyc_output
.grunt
bower_components
.lock-wscript
build/Release

# Dependencies
node_modules/
jspm_packages/
web_modules/

# TypeScript
*.tsbuildinfo

# Caches
.npm
.eslintcache
.stylelintcache
.node_repl_history
.cache
.parcel-cache
.vscode-test

# npm pack output
*.tgz

# Yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# dotenv (keep examples)
.env
.env.*
!.env.example

# Frameworks’ outputs (safe to keep even if you don’t use them)
.next
out
.nuxt
dist
.cache/
.temp
.svelte-kit/
**/.vitepress/dist
**/.vitepress/cache
.docusaurus
.serverless/
.fusebox/
.dynamodb/
.firebase/
.tern-port

# Vite logs
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# -----------------------------
# React Native / Expo extras
# -----------------------------
# Expo
.expo/
.expo-shared/
expo-env.d.ts
web-build/

# Metro
.metro-cache/
.metro-health-check*

# Generated native folders (Expo managed workflow)
ios/
android/

# Signing / credentials (keep out of git)
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# OS / IDE
.DS_Store
.vscode/
.idea/

# npm cache (local only)
.npm-cache/

# Claude Code local settings
.claude/
